<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>TCAS Hub - เว็บไซต์เพื่อเด็ก ม.6</title>
    <style>
        * {
            box-sizing: border-box;
            font-family: 'ChulaCharasNew', 'Helvetica Neue', Arial, sans-serif;
        }
        body {
            background-color: #f0f4f8;
            margin: 0;
            padding: 0;
            color: #333;
        }
        header {
            background: linear-gradient(135deg, #ff7675, #6c5ce7);
            color: white;
            text-align: center;
            padding: 40px 20px;
        }
        .container {
            max-width: 1000px;
            margin: -30px auto 40px auto;
            padding: 0 20px;
        }
        .card {
            background: white;
            border-radius: 16px;
            padding: 30px;
            margin-bottom: 30px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.05);
        }
        h2 {
            color: #2d3436;
            margin-top: 0;
            border-left: 5px solid #6c5ce7;
            padding-left: 10px;
        }
        /* Countdown Section */
        .countdown-container {
            display: flex;
            justify-content: center;
            gap: 20px;
            margin-top: 15px;
        }
        .time-box {
            background: #ffeaa7;
            padding: 15px 25px;
            border-radius: 8px;
            text-align: center;
            font-size: 24px;
            font-weight: bold;
            color: #d63031;
        }
        .time-box span {
            display: block;
            font-size: 14px;
            color: #636e72;
        }
        /* Grid Layout for Info & Calc */
        .grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 20px;
        }
        @media (max-width: 768px) {
            .grid { grid-template-columns: 1fr; }
        }
        /* Form & Inputs */
        .form-group { margin-bottom: 15px; }
        label { display: block; margin-bottom: 5px; font-weight: bold; }
        input, select {
            width: 100%;
            padding: 12px;
            border: 1px solid #dfe6e9;
            border-radius: 8px;
            font-size: 16px;
        }
        button {
            width: 100%;
            padding: 14px;
            background: #6c5ce7;
            color: white;
            border: none;
            border-radius: 8px;
            font-size: 18px;
            cursor: pointer;
            font-weight: bold;
        }
        button:hover { background: #5b4cc4; }
        /* Result Box */
        .result {
            margin-top: 20px;
            padding: 15px;
            border-radius: 8px;
            text-align: center;
            display: none;
            font-weight: bold;
        }
        /* Faculty Cards */
        .fac-list {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 15px;
        }
        .fac-item {
            background: #f9f9f9;
            padding: 15px;
            border-radius: 8px;
            border-left: 4px solid #ff7675;
        }
    </style>
</head>
<body>

<header>
    <h1>🎯 TCAS Platform For Dek 69-70</h1>
    <p>เพื่อนคู่คิดสำหรับเด็ก ม.ปลาย ที่กำลังจะเข้ามหาวิทยาลัย</p>
</header>

<div class="container">
    
    <div class="card" style="text-align: center;">
        <h2>⏳ นับถอยหลังสู่สนามสอบ TGAT/TPAT</h2>
        <div class="countdown-container">
            <div class="time-box"><div id="days">00</div><span>วัน</span></div>
            <div class="time-box"><div id="hours">00</div><span>ชั่วโมง</span></div>
            <div class="time-box"><div id="minutes">00</div><span>นาที</span></div>
        </div>
        <p style="color: #636e72; margin-top: 15px;">💡 สิ่งที่ควรเก็บตอนนี้: ลุยทำโจทย์เก่าภาษาอังกฤษ และพาร์ทคิดวิเคราะห์เบื้องต้น!</p>
    </div>

    <div class="grid">
        <div class="card">
            <h2>🧮 คำนวณโอกาสสอบติด</h2>
            <div class="form-group">
                <label>เลือกคณะเป้าหมาย:</label>
                <select id="faculty">
                    <option value="60">คณะวิศวกรรมศาสตร์ (คะแนนต่ำสุดปีก่อน: 60)</option>
                    <option value="55">คณะวิทยาศาสตร์ (คะแนนต่ำสุดปีก่อน: 55)</option>
                    <option value="65">คณะพาณิชยศาสตร์และการบัญชี (คะแนนต่ำสุดปีก่อน: 65)</option>
                </select>
            </div>
            <div class="form-group">
                <label>คะแนน TGAT (เต็ม 100):</label>
                <input type="number" id="tgat" placeholder="กรอกคะแนน">
            </div>
            <div class="form-group">
                <label>คะแนน A-Level เฉลี่ย (เต็ม 100):</label>
                <input type="number" id="alevel" placeholder="กรอกคะแนน">
            </div>
            <button onclick="calScore()">คำนวณคะแนน</button>
            <div id="resultBox" class="result"></div>
        </div>

        <div class="card">
            <h2>ℹ️ ข้อมูลคณะน่าสนใจ</h2>
            <div class="fac-list">
                <div class="fac-item">
                    <strong style="color: #6c5ce7;">💻 วิศวะคอมพิวเตอร์</strong><br>
                    • เรียน 4 ปี<br>
                    • ค่าเทอม: ~25,000 บาท/เทอม<br>
                    • เน้น: เขียนโค้ด, พัฒนาระบบ
                </div>
                <div class="fac-item">
                    <strong style="color: #6c5ce7;">📈 บริหารธุรกิจ</strong><br>
                    • เรียน 4 ปี<br>
                    • ค่าเทอม: ~20,000 บาท/เทอม<br>
                    • เน้น: การตลาด, การเงิน, จัดการ
                </div>
                <div class="fac-item">
                    <strong style="color: #ff7675;">🩺 แพทยศาสตร์</strong><br>
                    • เรียน 6 ปี<br>
                    • ค่าเทอม: ~30,000-50,000 บาท<br>
                    • เน้น: วิทยาศาสตร์การแพทย์, รักษาคน
                </div>
                <div class="fac-item">
                    <strong style="color: #ff7675;">🎨 มัณฑนศิลป์ / ออกแบบ</strong><br>
                    • เรียน 4 ปี<br>
                    • ค่าเทอม: ~28,500 บาท<br>
                    • เน้น: วาดรูป, ออกแบบ, ความคิดสร้างสรรค์
                </div>
            </div>
        </div>
    </div>

</div>

<script>
    // --- ฟังก์ชันคำนวณคะแนน ---
    function calScore() {
        let target = parseFloat(document.getElementById('faculty').value);
        let tgat = parseFloat(document.getElementById('tgat').value) || 0;
        let alevel = parseFloat(document.getElementById('alevel').value) || 0;
        
        // สมมติค่าน้ำหนัก: TGAT 50% + A-Level 50%
        let total = (tgat * 0.5) + (alevel * 0.5);
        
        let res = document.getElementById('resultBox');
        res.style.display = "block";
        
        if (total >= target) {
            res.style.backgroundColor = "#d4edda";
            res.style.color = "#155724";
            res.innerHTML = `คะแนนของคุณ: ${total.toFixed(2)} ยินดีด้วย มีโอกาสติดสูงมาก!`;
        } else {
            res.style.backgroundColor = "#f8d7da";
            res.style.color = "#721c24";
            res.innerHTML = `คะแนนของคุณ: ${total.toFixed(2)} ยังต่ำกว่าเกณฑ์ปีก่อน พยายามอีกนิดนะ!`;
        }
    }

    // --- ฟังก์ชันนับถอยหลัง (สมมติวันสอบคือช่วงธันวาคมของทุกปี) ---
    function updateCountdown() {
        // ตั้งเป้าหมายเป็นปลายปีนี้ (คุณปรับเปลี่ยนวันที่ตรงนี้ได้)
        const targetDate = new Date("December 10, 2026 09:00:00").getTime();
        const now = new Date().getTime();
        const difference = targetDate - now;

        const d = Math.floor(difference / (1000 * 60 * 60 * 24));
        const h = Math.floor((difference % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
        const m = Math.floor((difference % (1000 * 60 * 60)) / (1000 * 60));

        document.getElementById('days').innerText = d > 0 ? d : 0;
        document.getElementById('hours').innerText = h > 0 ? h : 0;
        document.getElementById('minutes').innerText = m > 0 ? m : 0;
    }
    setInterval(updateCountdown, 1000);
    updateCountdown();
</script>

</body>
</html>
