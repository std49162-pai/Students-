<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>TCAS Score Calculator & Predictor</title>
    <style>
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background-color: #f4f7f6;
            color: #333;
            margin: 0;
            padding: 20px;
        }
        .container {
            max-width: 600px;
            background: white;
            margin: 0 auto;
            padding: 30px;
            border-radius: 12px;
            box-shadow: 0 4px 15px rgba(0,0,0,0.05);
        }
        h2 {
            color: #2c3e50;
            text-align: center;
            margin-bottom: 25px;
        }
        .form-group {
            margin-bottom: 20px;
        }
        label {
            display: block;
            margin-bottom: 8px;
            font-weight: bold;
            color: #34495e;
        }
        input[type="number"], select {
            width: 100%;
            padding: 10px;
            border: 1px solid #ccc;
            border-radius: 6px;
            box-sizing: border-box;
            font-size: 16px;
        }
        button {
            width: 100%;
            padding: 12px;
            background-color: #3498db;
            color: white;
            border: none;
            border-radius: 6px;
            font-size: 18px;
            cursor: pointer;
            transition: background 0.3s;
        }
        button:hover {
            background-color: #2980b9;
        }
        .result-box {
            margin-top: 30px;
            padding: 20px;
            border-radius: 8px;
            text-align: center;
            display: none;
        }
        .safe { background-color: #d4edda; color: #155724; border: 1px solid #c3e6cb; }
        .risk { background-color: #fff3cd; color: #856404; border: 1px solid #ffeeba; }
        .danger { background-color: #f8d7da; color: #721c24; border: 1px solid #f5c6cb; }
    </style>
</head>
<body>

<div class="container">
    <h2>🧮 ระบบคำนวณคะแนน & ประเมินโอกาสติด</h2>
    
    <div class="form-group">
        <label for="faculty">เลือกคณะที่สนใจ:</label>
        <select id="faculty">
            <option value="engineering">คณะวิศวกรรมศาสตร์ (คะแนนต่ำสุดปีที่แล้ว: 60)</option>
            <option value="comsci">คณะวิทยาศาสตร์ คอมพิวเตอร์ (คะแนนต่ำสุดปีที่แล้ว: 55)</option>
            <option value="arts">คณะอักษรศาสตร์ (คะแนนต่ำสุดปีที่แล้ว: 68)</option>
        </select>
    </div>

    <div class="form-group">
        <label for="tgat">คะแนน TGAT (เต็ม 100):</label>
        <input type="number" id="tgat" min="0" max="100" placeholder="เช่น 65.5">
    </div>

    <div class="form-group">
        <label for="alevel">คะแนน A-Level เฉลี่ย (เต็ม 100):</label>
        <input type="number" id="alevel" min="0" max="100" placeholder="เช่น 58.0">
    </div>

    <button onclick="calculateScore()">คำนวณโอกาสสอบติด</button>

    <div id="result" class="result-box">
        <h3 id="score-display">คะแนนของคุณ: 0.00</h3>
        <p id="status-display"></p>
    </div>
</div>

<script>
    function calculateScore() {
        // 1. ดึงค่าจากฟอร์ม
        const faculty = document.getElementById('faculty').value;
        const tgat = parseFloat(document.getElementById('tgat').value) || 0;
        const alevel = parseFloat(document.getElementById('alevel').value) || 0;
        
        // 2. สมมติสูตรคำนวณ: คิดจาก TGAT 40% + A-Level 60%
        let myScore = (tgat * 0.4) + (alevel * 0.6);
        myScore = myScore.toFixed(2);
        
        // 3. กำหนดคะแนนต่ำสุดของแต่ละคณะ (เกณฑ์สมมติ)
        let baseScore = 0;
        if (faculty === 'engineering') baseScore = 60;
        else if (faculty === 'comsci') baseScore = 55;
        else if (faculty === 'arts') baseScore = 68;
        
        // 4. ประมวลผลและแสดงผลลัพธ์
        const resultBox = document.getElementById('result');
        const scoreDisplay = document.getElementById('score-display');
        const statusDisplay = document.getElementById('status-display');
        
        resultBox.style.display = 'block';
        scoreDisplay.innerHTML = `คะแนนเฉลี่ยสะสมของคุณคือ: <strong>${myScore}</strong>`;
        
        // ล้าง class เก่าออกก่อน
        resultBox.className = 'result-box';
        
        // เทียบโอกาสติด
        if (myScore >= baseScore + 5) {
            resultBox.classList.add('safe');
            statusDisplay.innerHTML = "🎉 โอกาสติดสูงมาก! คะแนนคุณปลอดภัยเมื่อเทียบกับปีที่แล้ว";
        } else if (myScore >= baseScore - 2) {
            resultBox.classList.add('risk');
            statusDisplay.innerHTML = "⚖️ ลุ้นเหนื่อยหน่อย! คะแนนคุณปริ่ม ๆ กับคะแนนต่ำสุดปีก่อน";
        } else {
            resultBox.classList.add('danger');
            statusDisplay.innerHTML = "🚨 เสี่ยงมาก! แนะนำให้เร่งอ่านหนังสือเพิ่มคะแนนในรอบถัดไป";
        }
    }
</script>

</body>
</html>
