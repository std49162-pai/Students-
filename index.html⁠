<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>DEK-DASHBOARD // ม.6 ต้องรอด</title>
    <style>
        :root {
            --bg-color: #0b0f19;
            --card-bg: #151f32;
            --accent-purple: #6c5ce7;
            --accent-pink: #ff7675;
            --text-main: #ffffff;
            --text-muted: #8fa0dd;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
            font-family: 'Kanit', -apple-system, sans-serif;
        }

        body {
            background-color: var(--bg-color);
            color: var(--text-main);
            padding: 20px;
        }

        .wrapper {
            max-width: 1200px;
            margin: 0 auto;
        }

        /* Header */
        header {
            text-align: center;
            padding: 40px 0;
        }

        header h1 {
            font-size: 2.5rem;
            background: linear-gradient(45deg, #ff7675, #6c5ce7);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            margin-bottom: 10px;
        }

        header p {
            color: var(--text-muted);
        }

        /* Main Grid */
        .main-grid {
            display: grid;
            grid-template-columns: 2fr 1fr;
            gap: 20px;
        }

        @media (max-width: 900px) {
            .main-grid { grid-template-columns: 1fr; }
        }

        .card {
            background: var(--card-bg);
            border-radius: 16px;
            padding: 25px;
            border: 1px solid rgba(255,255,255,0.05);
        }

        h2 {
            font-size: 1.3rem;
            margin-bottom: 20px;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        /* Countdown */
        .countdown-widget {
            display: flex;
            justify-content: space-around;
            background: rgba(0,0,0,0.2);
            padding: 20px;
            border-radius: 12px;
            text-align: center;
        }

        .time-unit {
            font-size: 2rem;
            font-weight: bold;
            color: var(--accent-pink);
        }

        .time-unit span {
            display: block;
            font-size: 0.8rem;
            color: var(--text-muted);
        }

        /* Calculator Form */
        .form-group {
            margin-bottom: 15px;
        }

        label {
            display: block;
            font-size: 0.9rem;
            color: var(--text-muted);
            margin-bottom: 8px;
        }

        input, select {
            width: 100%;
            padding: 12px;
            background: #0b0f19;
            border: 1px solid rgba(255,255,255,0.1);
            border-radius: 8px;
            color: white;
            font-size: 1rem;
        }

        input:focus, select:focus {
            outline: 1px solid var(--accent-purple);
        }

        button {
            width: 100%;
            padding: 14px;
            background: var(--accent-purple);
            color: white;
            border: none;
            border-radius: 8px;
            font-size: 1rem;
            font-weight: bold;
            cursor: pointer;
            transition: 0.2s;
        }

        button:hover {
            background: #5b4cc4;
            transform: translateY(-2px);
        }

        .result-panel {
            margin-top: 15px;
            padding: 15px;
            border-radius: 8px;
            text-align: center;
            font-weight: bold;
            display: none;
        }

        /* Info List */
        .info-item {
            background: rgba(255,255,255,0.02);
            padding: 15px;
            border-radius: 8px;
            margin-bottom: 10px;
            border-left: 4px solid var(--accent-purple);
        }

        .info-item h4 { color: var(--accent-pink); margin-bottom: 5px; }
        .info-item p { font-size: 0.9rem; color: var(--text-muted); }

    </style>
</head>
<body>

<div class="wrapper">
    <header>
        <h1>⚡ DEK-DASHBOARD</h1>
        <p>รวมทุกเครื่องมือสำหรับเด็ก ม.6 ที่จะสอบเข้ามหาวิทยาลัย</p>
    </header>

    <div class="main-grid">
        <div style="display: flex; flex-direction: column; gap: 20px;">
            
            <div class="card">
                <h2>🧮 ระบบคำนวณคะแนน TCAS (สูตรจำลอง)</h2>
                <div class="form-group">
                    <label>เลือกกลุ่มคณะที่อยากเข้า</label>
                    <select id="targetGroup">
                        <option value="55">สายวิทย์-คอมพิวเตอร์ / ไอที (เกณฑ์คะแนนขั้นต่ำปีก่อน: 55)</option>
                        <option value="62">สายวิศวกรรมศาสตร์ (เกณฑ์คะแนนขั้นต่ำปีก่อน: 62)</option>
                        <option value="65">สายบริหาร / บัญชี (เกณฑ์คะแนนขั้นต่ำปีก่อน: 65)</option>
                    </select>
                </div>
                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 15px;">
                    <div class="form-group">
                        <label>คะแนน TGAT (เต็ม 100)</label>
                        <input type="number" id="tgatScore" placeholder="กรอกคะแนน">
                    </div>
                    <div class="form-group">
                        <label>คะแนน A-Level เฉลี่ย (เต็ม 100)</label>
                        <input type="number" id="alevelScore" placeholder="กรอกคะแนน">
                    </div>
                </div>
                <button onclick="checkChance()">ประเมินโอกาสสอบติด</button>
                <div id="resultDisplay" class="result-panel"></div>
            </div>

            <div class="card">
                <h2>📚 Checklist บทเรียนห้ามพลาด (Test Blueprint)</h2>
                <div class="info-item">
                    <h4>วิชา TGAT1 (English Communication)</h4>
                    <p>เน้นเก็บ: Reading Comprehension และ Speaking Skill ออกสอบสัดส่วนเยอะที่สุด</p>
                </div>
                <div class="info-item">
                    <h4>วิชา A-Level คณิตศาสตร์ 1</h4>
                    <p>เน้นเก็บ: สถิติและข้อมูล, แคลคูลัสเบื้องต้น เป็นกลุ่มบทโกยคะแนนของทุกปี</p>
                </div>
            </div>

        </div>

        <div style="display: flex; flex-direction: column; gap: 20px;">
            
            <div class="card">
                <h2>⏳ นับถอยหลังวันสอบ (TGAT/TPAT)</h2>
                <div class="countdown-widget">
                    <div class="time-unit"><div id="d">00</div><span>วัน</span></div>
                    <div class="time-unit"><div id="h">00</div><span>ชั่วโมง</span></div>
                    <div class="time-unit"><div id="m">00</div><span>นาที</span></div>
                </div>
            </div>

            <div class="card">
                <h2>🔍 ข้อมูลคณะด่วน</h2>
                <div class="info-item" style="border-left-color: var(--accent-pink);">
                    <h4>คณะวิศวกรรมศาสตร์</h4>
                    <p>เรียน 4 ปี | ค่าเทอมเฉลี่ย: 25,000 บ.</p>
                </div>
                <div class="info-item" style="border-left-color: var(--accent-pink);">
                    <h4>คณะพาณิชยศาสตร์และการบัญชี</h4>
                    <p>เรียน 4 ปี | ค่าเทอมเฉลี่ย: 20,000 บ.</p>
                </div>
                <div class="info-item" style="border-left-color: var(--accent-pink);">
                    <h4>คณะแพทยศาสตร์</h4>
                    <p>เรียน 6 ปี | ค่าเทอมเฉลี่ย: 40,000 บ.</p>
                </div>
            </div>

        </div>
    </div>
</div>

<script>
    // คำนวณคะแนน
    function checkChance() {
        const target = parseFloat(document.getElementById('targetGroup').value);
        const tgat = parseFloat(document.getElementById('tgatScore').value) || 0;
        const alevel = parseFloat(document.getElementById('alevelScore').value) || 0;
        
        // คิดสัดส่วน 50/50
        const myTotal = (tgat * 0.5) + (alevel * 0.5);
        const display = document.getElementById('resultDisplay');
        display.style.display = "block";

        if (myTotal >= target) {
            display.style.background = "#27ae60";
            display.style.color = "#fff";
            display.innerHTML = `คะแนนรวมของคุณ: ${myTotal.toFixed(2)} — [มีโอกาสติดสูงมาก]`;
        } else {
            display.style.background = "#c0392b";
            display.style.color = "#fff";
            display.innerHTML = `คะแนนรวมของคุณ: ${myTotal.toFixed(2)} — [ยังต่ำกว่าเกณฑ์ปีก่อน พยายามดึงคะแนนเพิ่มอีก]`;
        }
    }

    // ระบบเวลานับถอยหลัง
    function liveCountdown() {
        const examDate = new Date("December 12, 2026 09:00:00").getTime();
        const now = new Date().getTime();
        const gap = examDate - now;

        const days = Math.floor(gap / (1000 * 60 * 60 * 24));
        const hours = Math.floor((gap % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
        const minutes = Math.floor((gap % (1000 * 60 * 60)) / (1000 * 60));

        document.getElementById('d').innerText = days > 0 ? days : 0;
        document.getElementById('h').innerText = hours > 0 ? hours : 0;
        document.getElementById('m').innerText = minutes > 0 ? minutes : 0;
    }
    setInterval(liveCountdown, 1000);
    liveCountdown();
</script>

</body>
</html>
